{
  "cleanUrls": false,
  "redirects": [
    { "source": "/mr-:iid(\\d+)", "destination": "/mr-:iid/index.html", "type": 301 },
    { "source": "/v:version(\\d+\\.\\d+\\.\\d+)", "destination": "/v:version/index.html", "type": 301 }
  ],
  "rewrites": [
    { "source": "**", "destination": "/index.html" }
  ]
}
