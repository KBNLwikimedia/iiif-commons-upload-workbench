# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored so secrets stay out of the repo.

# OAuth 2.0 consumer registered at:
# https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration/propose/oauth2
#
# Upload Workbench can reuse the upload-stash-viewer consumer's client_id as long
# as the redirect URIs match. Otherwise, register a new consumer.
VITE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID_HERE
VITE_OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# Optional: paste an owner-only access token to skip the PKCE redirect flow
# during local development. Leave empty to use the normal login flow.
VITE_OWNER_ACCESS_TOKEN=
